generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Usuario {
  id           Int                 @id @default(autoincrement())
  authId       String?             @unique // Supabase auth UUID
  nombre       String
  email        String              @unique
  rol          String              @default("operador") // admin | operador | visualizador
  activo       Boolean             @default(true)
  ultimoAcceso DateTime?
  creadoEn     DateTime            @default(now())
  actividades  RegistroActividad[]
}

model Vehiculo {
  id                 Int       @id @default(autoincrement())
  categoria          String
  patente            String    @unique
  modelo             String
  marca              String
  anio               Int
  estado             String    @default("disponible")
  ubicacion          String    @default("")
  kmActuales         Int       @default(0)
  fechaIncorporacion DateTime  @default(now())
  proximaVenta       Boolean   @default(false)
  notas              String    @default("")
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt
  reservas           Reserva[]
  alertas            Alerta[]
}

model Reserva {
  id            Int      @id @default(autoincrement())
  vehiculoId    Int
  vehiculo      Vehiculo @relation(fields: [vehiculoId], references: [id])
  clienteNombre String
  clienteEmail  String   @default("")
  clienteTel    String   @default("")
  fechaInicio   DateTime
  fechaFin      DateTime
  estado        String   @default("activa")
  notas         String   @default("")
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model Alerta {
  id          Int       @id @default(autoincrement())
  vehiculoId  Int?
  vehiculo    Vehiculo? @relation(fields: [vehiculoId], references: [id])
  tipo        String
  descripcion String
  fecha       DateTime  @default(now())
  leida       Boolean   @default(false)
  enviada     Boolean   @default(false)
  creadoEn    DateTime  @default(now())
}

model ConfigAlerta {
  id                   Int      @id @default(autoincrement())
  nombre               String
  tipo                 String
  frecuencia           String
  horaEnvio            String?
  canal                String   @default("email")
  destinatarios        String
  mensajePersonalizado String?
  activa               Boolean  @default(true)
  creadoEn             DateTime @default(now())
}

model RegistroActividad {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  accion    String
  detalle   String   @default("")
  entidad   String   @default("")
  entidadId Int?
  creadoEn  DateTime @default(now())
}
